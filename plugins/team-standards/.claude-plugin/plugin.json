{
  "name": "team-standards",
  "version": "1.0.0",
  "description": "Core development team plugin - code review, PR creation, ticket workflows, and quality gates",
  "skills": [
    "skills/code-review/SKILL.md",
    "skills/pr-create/SKILL.md",
    "skills/ticket-workflow/SKILL.md"
  ],
  "agents": [
    "agents/reviewer.md"
  ],
  "hooks": [
    {
      "event": "PostToolUse",
      "matcher": "Edit|Write",
      "command": "hooks/lint-check.sh"
    },
    {
      "event": "PreToolUse",
      "matcher": "Bash",
      "if": "Bash(git commit *)",
      "command": "hooks/pre-commit-checks.sh"
    }
  ],
  "mcp": ".mcp.json"
}
